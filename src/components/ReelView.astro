---
import type { Project } from '../data/projects';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div id="reel-view">
  <div class="back-hint">← tap name to go back · or swipe down</div>
  <button class="reel-sound" id="rsound">♪ Unmute</button>

  <div class="reel" id="reel">
    {projects.map((project, i) => (
      <div class="slide" data-idx={i}>
        <video loop muted playsinline preload="metadata">
          <source src={project.videoSrc} type="video/mp4" />
        </video>
        <div class="slide-shade"></div>
        <div class="slide-info">
          <div class="si-type">{project.type}</div>
          <div class="si-title">
            {project.titleLines.map((line, li) => (
              <>
                {line}
                {li < project.titleLines.length - 1 && <br />}
              </>
            ))}
          </div>
          <div class="si-credits">
            <div class="si-credit">Dir <b>{project.director}</b></div>
            <div class="si-credit">Prod <b>{project.production}</b></div>
            <div class="si-credit">Year <b>{project.year}</b></div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="reel-dots" id="reel-dots"></div>

  <div class="strip">
    {projects.map((project, i) => (
      <div class={`strip-item${i === 0 ? ' active' : ''}`} data-jump={i}>
        <img src={project.thumbnail} alt={project.title} />
        <div class="strip-num">{String(i + 1).padStart(2, '0')}</div>
      </div>
    ))}
  </div>
</div>
